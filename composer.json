{
  "name": "ernilambar/optiz",
  "description": "Lightweight schema-driven settings framework for WordPress",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "admin",
    "framework",
    "options",
    "schema",
    "settings",
    "wordpress"
  ],
  "authors": [
    {
      "name": "Nilambar Sharma",
      "email": "nilambar@outlook.com",
      "homepage": "https://www.nilambar.net",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/ernilambar/optiz",
  "support": {
    "issues": "https://github.com/ernilambar/optiz/issues",
    "source": "https://github.com/ernilambar/optiz"
  },
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1",
    "ernilambar/coding-standard": "^1.0",
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "phpcompatibility/php-compatibility": "^10@alpha",
    "phpunit/phpunit": "^9.6 || ^10 || ^11",
    "slevomat/coding-standard": "^8.22",
    "squizlabs/php_codesniffer": "^3.13",
    "wp-coding-standards/wpcs": "^3.3"
  },
  "minimum-stability": "stable",
  "autoload": {
    "psr-4": {
      "Nilambar\\Optiz\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nilambar\\Optiz\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true
    },
    "optimize-autoloader": true,
    "platform": {
      "php": "8.0"
    },
    "sort-packages": true
  },
  "scripts": {
    "format": "@php ./vendor/bin/phpcbf --report-full --report-summary .",
    "lint": [
      "@lint:php",
      "@phpcs"
    ],
    "lint:php": "@php ./vendor/bin/parallel-lint -p php --exclude .git --exclude vendor --exclude node_modules .",
    "phpcs": "@php ./vendor/bin/phpcs --report-full --report-summary .",
    "test": "@php ./vendor/bin/phpunit"
  }
}
